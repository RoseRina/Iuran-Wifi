# ============================================
# WhatsApp Self-Hosted Gateway Configuration
# ============================================

# Token rahasia untuk auth API (ganti dengan string random yang kuat!)
# Generate contoh: openssl rand -hex 32
WA_GATEWAY_TOKEN=ganti-dengan-token-rahasia-kamu-minimal-32-karakter

# Port server HTTP (default: 3000)
PORT=3000

# Path database SQLite untuk menyimpan session WhatsApp
DB_PATH=./data/whatsapp.db
